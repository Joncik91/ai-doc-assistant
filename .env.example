# Backend environment variables (copy to .env in backend/ or set in production)
DEBUG=true
HOST=0.0.0.0
PORT=8000

# LLM Configuration
LLM_PROVIDER=deepseek # or ollama
LLM_API_KEY=your-deepseek-api-key-here # optional for ollama
LLM_BASE_URL= # deepseek default: https://api.deepseek.com/v1, ollama default: http://localhost:11434
LLM_MODEL=deepseek-chat # set to an Ollama model such as llama3.1 when LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=2000

# Vector Store
CHROMA_PERSIST_DIRECTORY=./data/chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MAX_UPLOAD_SIZE_BYTES=10485760
DOCUMENT_STORAGE_DIRECTORY=./data/documents

# Database
DATABASE_URL=sqlite:///./data/app.db

# Auth
SECRET_KEY=replace-me-with-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-me-with-admin-password
BOOTSTRAP_API_KEY=replace-me-with-api-key

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_MINUTES=60
